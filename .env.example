# DATABASE_URL: PostgreSQL connection string. Requires PostGIS extension for geo queries.
DATABASE_URL="postgres://localhost:5432/petlink"

# DB_SCHEMA: PostgreSQL schema for PetLink tables (default: petlink).
DB_SCHEMA="petlink"

# APP_URL: The URL where PetLink is hosted.
APP_URL="http://localhost:3000"

# JWT_SECRET: Secret key for signing JWT tokens. Change in production.
JWT_SECRET="change-me-in-production"

# Stripe: Required for payment processing.
STRIPE_SECRET_KEY=""
STRIPE_PUBLISHABLE_KEY=""  # Frontend Stripe Elements (mapped via vite.config.ts)
STRIPE_WEBHOOK_SECRET=""
# STRIPE_PRO_PRICE_ID=""  # Stripe Price ID for Pro subscription (omit for dev-mode direct activation)

# S3 Storage: For pet/sitter photo uploads. Supports AWS S3 or S3-compatible (MinIO).
S3_BUCKET=""
S3_REGION="us-east-1"
S3_ACCESS_KEY=""
S3_SECRET_KEY=""
# S3_ENDPOINT="" # Uncomment for MinIO or S3-compatible storage

# OAuth: Google Sign-In
GOOGLE_CLIENT_ID=""

# OAuth: Apple Sign-In (optional — requires Apple Developer account)
# APPLE_CLIENT_ID=""

# OAuth: Facebook Login
FACEBOOK_APP_ID=""
FACEBOOK_APP_SECRET=""  # Backend-only secret (not exposed to frontend)

# Admin: Email of the admin user (case-insensitive). Controls access to /admin endpoints.
ADMIN_EMAIL=""
